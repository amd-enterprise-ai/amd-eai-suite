# Required: RabbitMQ credentials from AIRM UI cluster onboarding
RABBITMQ_USER=<Cluster ID from AIRM UI>
RABBITMQ_PASSWORD=<User secret from AIRM UI>

# Required: Kubernetes cluster name
KUBE_CLUSTER_NAME=<Cluster Name>

# Optional: RabbitMQ connection (defaults: localhost, 5672)
# RABBITMQ_HOST=localhost
# RABBITMQ_PORT=5672

# Optional: HTTP server port (default: 8000)
# HTTP_PORT=8000

# Optional: Health check port
# HEALTH_PORT=8081

# Optional: Webhooks
# WEBHOOKS_ENABLED=true
# WEBHOOK_PORT=9443
# WEBHOOKS_CERT_PATH=/etc/mutating-webhook/tls/
