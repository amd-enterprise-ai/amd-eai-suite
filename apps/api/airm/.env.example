RABBITMQ_ADMIN_PASSWORD="guest"
RABBITMQ_AIRM_COMMON_VHOST="vh_airm_common"
RABBITMQ_AIRM_COMMON_QUEUE="airm_common"


POST_REGISTRATION_REDIRECT_URL="http://localhost:8010"
PROMETHEUS_URL="http://localhost:9090"
