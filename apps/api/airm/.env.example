# Database
DATABASE_HOST="localhost"
DATABASE_PORT=5432
DATABASE_USER="postgres"
DATABASE_PASSWORD="postgres"

# Keycloak
KEYCLOAK_INTERNAL_URL="http://localhost:8080"
KEYCLOAK_ADMIN_CLIENT_ID="your-keycloak-admin-client-id"
KEYCLOAK_ADMIN_CLIENT_SECRET="your-keycloak-admin-client-secret"
