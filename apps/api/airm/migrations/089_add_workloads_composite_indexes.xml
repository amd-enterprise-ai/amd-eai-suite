<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns:ext="http://www.liquibase.org/xml/ns/dbchangelog-ext" xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.6.xsd
                   http://www.liquibase.org/xml/ns/dbchangelog-ext http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-ext.xsd">

<changeSet author="kevin" id="add-workloads-composite-indexes">
    <!-- Add composite indexes for common filter patterns (project + cluster scoped) -->

    <!-- Cluster-scoped indexes for type and display_name filtering -->
    <createIndex indexName="ix_workloads_cluster_id_type" tableName="workloads">
      <column name="cluster_id"/>
      <column name="type"/>
    </createIndex>

    <createIndex indexName="ix_workloads_cluster_id_display_name" tableName="workloads">
      <column name="cluster_id"/>
      <column name="display_name"/>
    </createIndex>
</changeSet>
</databaseChangeLog>
