<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <changeSet id="003-create-inference-models-table" author="system">
        <comment>Create inference_models table for managing onboarded models</comment>

        <createTable tableName="inference_models">
            <column name="id" type="UUID" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="namespace" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="onboarding_status" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="model_weights_path" type="VARCHAR(500)"/>
            <column name="canonical_name" type="VARCHAR(255)"/>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="created_by" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="updated_by" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createIndex tableName="inference_models" indexName="idx_inference_models_namespace">
            <column name="namespace"/>
        </createIndex>

        <addUniqueConstraint tableName="inference_models"
                             columnNames="name, namespace"
                             constraintName="inference_models_name_namespace_key"/>

    </changeSet>

</databaseChangeLog>
