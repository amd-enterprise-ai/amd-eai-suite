{
  "name": "aiwb-ui",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.22.0",
  "scripts": {
    "dev": "next --version && cross-env NODE_TLS_REJECT_UNAUTHORIZED=0 next dev --turbopack -p 8011",
    "build": "next --version && next build  --turbopack",
    "start": "next start -p 8000",
    "lint": "biome lint .",
    "format:fix": "biome format --write .",
    "format:check": "biome format .",
    "format:staged": "biome format --write --staged --no-errors-on-unmatched .",
    "format": "pnpm format:check || pnpm format:fix",
    "typecheck": "pnpm tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ci": "vitest run --silent",
    "coverage": "vitest run --coverage"
  },
  "pnpm": {
    "overrides": {
      "motion-dom": "12.8.0",
      "motion-utils": "12.7.5"
    }
  },
  "dependencies": {
    "@amdenterpriseai/assets": "workspace:*",
    "@amdenterpriseai/components": "workspace:*",
    "@amdenterpriseai/hooks": "workspace:*",
    "@amdenterpriseai/layouts": "workspace:*",
    "@amdenterpriseai/types": "workspace:*",
    "@amdenterpriseai/utils": "workspace:*",
    "i18next": "*",
    "@heroui/react": "*",
    "@hookform/resolvers": "*",
    "@tabler/icons-react": "*",
    "@tanstack/react-query": "*",
    "ansi-to-react": "*",
    "date-fns": "*",
    "jsonwebtoken": "*",
    "lodash": "*",
    "next": "*",
    "next-auth": "*",
    "next-i18next": "*",
    "next-themes": "*",
    "react": "*",
    "react-dom": "*",
    "react-hook-form": "*",
    "react-markdown": "*",
    "react-syntax-highlighter": "*",
    "react-toastify": "*",
    "recharts": "*",
    "rehype-mathjax": "*",
    "remark-gfm": "*",
    "remark-math": "*",
    "uuid": "*",
    "winston": "*",
    "yaml": "*",
    "zod": "*"
  },
  "devDependencies": {
    "@biomejs/biome": "*",
    "@ladle/react": "*",
    "@mdx-js/react": "*",
    "@svgr/webpack": "*",
    "@tailwindcss/postcss": "*",
    "@tailwindcss/typography": "*",
    "@testing-library/jest-dom": "*",
    "@testing-library/react": "*",
    "@testing-library/react-hooks": "*",
    "@testing-library/user-event": "*",
    "@types/jsdom": "*",
    "@types/jsonwebtoken": "*",
    "@types/lodash": "*",
    "@types/node": "*",
    "@types/react": "*",
    "@types/react-dom": "*",
    "@types/react-syntax-highlighter": "*",
    "@types/uuid": "*",
    "@vitejs/plugin-react": "*",
    "@vitest/browser": "*",
    "@vitest/coverage-v8": "*",
    "@vitest/ui": "*",
    "autoprefixer": "*",
    "cross-env": "*",
    "jsdom": "*",
    "postcss": "*",
    "tailwindcss": "*",
    "typescript": "*",
    "vite": "*",
    "vitest": "*"
  }
}
