{
  "name": "@amdenterpriseai/components",
  "type": "module",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "sideEffects": ["**/*.css"],
  "scripts": {
    "build:styles": "postcss ./src/styles.css -o ./dist/index.css",
    "build:components": "tsc",
    "dev:styles": "postcss ./src/styles.css -o ./dist/index.css --watch",
    "dev:components": "tsc --watch",
    "check-types": "tsc --noEmit",
    "ladle": "ladle serve"
  },
  "dependencies": {
    "@amdenterpriseai/assets": "workspace:*",
    "@amdenterpriseai/hooks": "workspace:*",
    "@amdenterpriseai/layouts": "workspace:*",
    "@amdenterpriseai/types": "workspace:*",
    "@amdenterpriseai/utils": "workspace:*"
  },
  "peerDependencies": {
    "@heroui/react": "*",
    "@tabler/icons-react": "*",
    "i18next": "*",
    "next-i18next": "*",
    "react": "*",
    "react-dom": "*"
  },
  "devDependencies": {
    "@amdenterpriseai/tailwind-config": "workspace:*",
    "@ladle/react": "*",
    "@svgr/webpack": "*",
    "@tailwindcss/postcss": "*",
    "@tailwindcss/typography": "*",
    "@types/react": "*",
    "@vitejs/plugin-react": "*",
    "postcss": "*",
    "postcss-cli": "*",
    "tailwindcss": "*",
    "typescript": "5.9.2",
    "vite": "*"
  },
  "exports": {
    "./styles.css": "./dist/index.css",
    ".": "./src/index.ts"
  }
}
